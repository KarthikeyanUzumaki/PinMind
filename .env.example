# PinMind Environment Configuration (Template)

# 1. Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 2. Supabase PostgreSQL Connection URL
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# 3. Firebase Auth Credentials
FIREBASE_SERVICE_ACCOUNT_JSON=firebase_service_account.json
SECRET_KEY=GENERATE_A_RANDOM_SECRET_KEY_FOR_JWT

# 4. Cognee Graph Memory Engine Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=768

ENABLE_BACKEND_ACCESS_CONTROL=false
